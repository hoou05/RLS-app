{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RLS Screening Feature Schema v1",
  "type": "object",
  "properties": {
    "tier": { "enum": ["tier1", "tier2"] },
    "sleep_duration_minutes": { "type": ["number", "null"] },
    "sleep_efficiency": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "resting_heart_rate": { "type": ["number", "null"] },
    "mean_heart_rate": { "type": ["number", "null"] },
    "step_count": { "type": ["integer", "null"], "minimum": 0 },
    "activity_minutes": { "type": ["number", "null"], "minimum": 0 },
    "age": { "type": ["integer", "null"] },
    "sex": { "type": ["string", "null"] },
    "height": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "weight": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "min_heart_rate": { "type": ["number", "null"] },
    "max_heart_rate": { "type": ["number", "null"] },
    "experiment_features": { "type": "object" },
    "missing_mask_json": { "type": "object" },
    "urge_to_move_legs": { "type": ["integer", "null"], "minimum": 0, "maximum": 4 },
    "worse_at_rest": { "type": ["integer", "null"], "minimum": 0, "maximum": 4 },
    "relieved_by_movement": { "type": ["integer", "null"], "minimum": 0, "maximum": 4 },
    "worse_in_evening_or_night": { "type": ["integer", "null"], "minimum": 0, "maximum": 4 },
    "sleep_disturbance_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 10 },
    "symptom_frequency": { "type": ["integer", "null"], "minimum": 0, "maximum": 7 },
    "symptom_severity": { "type": ["integer", "null"], "minimum": 0, "maximum": 10 },
    "family_history_rls": { "type": ["boolean", "null"] },
    "diabetes": { "type": ["boolean", "null"] },
    "psychiatric_medication": { "type": ["boolean", "null"] },
    "non_leg_symptoms": { "type": ["boolean", "null"] }
  },
  "required": ["tier", "missing_mask_json"]
}
